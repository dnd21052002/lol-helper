{
  "name": "lol-helper",
  "version": "0.1.0",
  "private": true,
  "description": "All-in-one desktop helper for League of Legends",
  "main": "out/main/index.js",
  "author": "ndiepdev",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "1.7.7",
    "electron-log": "5.2.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.27.0",
    "ws": "^8.18.0",
    "zustand": "4.5.5"
  },
  "devDependencies": {
    "@types/node": "20.16.10",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "4.3.2",
    "electron": "32.1.2",
    "electron-builder": "25.0.5",
    "electron-vite": "2.3.0",
    "typescript": "5.6.2",
    "vite": "5.4.8"
  },
  "build": {
    "appId": "dev.ndiep.lol-helper",
    "productName": "lol-helper",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
